{
  "name": "polaroid-studio",
  "version": "1.0.0",
  "description": "Cross-platform desktop app for turning images into realistic Polaroid-style photos.",
  "main": "dist-electron/main.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:app": "wait-on tcp:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "build": "npm run typecheck && npm run build:renderer && npm run build:electron",
    "build:pwa": "npm run typecheck && npm run build:renderer",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "mobile:sync": "npm run build:pwa && cap sync",
    "android:add": "cap add android",
    "android:sync": "npm run build:pwa && cap sync android",
    "android:open": "cap open android",
    "android:build": "npm run build:pwa && cap sync android && cap build android",
    "ios:add": "cap add ios",
    "ios:sync": "npm run build:pwa && cap sync ios",
    "ios:open": "cap open ios",
    "ios:build": "npm run build:pwa && cap sync ios && cap build ios",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/core": "^7.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@capacitor/android": "^7.2.0",
    "@capacitor/cli": "^7.2.0",
    "@capacitor/ios": "^7.2.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.polaroidstudio.desktop",
    "productName": "Polaroid Studio",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.photography"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Graphics"
    }
  }
}
